MODEL_ROUTER_ENV=development
MODEL_ROUTER_DATABASE_URL=sqlite:///./model_router.db
MODEL_ROUTER_JWT_SECRET_KEY=change-me
MODEL_ROUTER_ACCESS_TOKEN_TTL_MINUTES=15
MODEL_ROUTER_REFRESH_TOKEN_TTL_DAYS=30
MODEL_ROUTER_REFRESH_COOKIE_SECURE=false
MODEL_ROUTER_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Optional bootstrap values for first startup.
MODEL_ROUTER_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
MODEL_ROUTER_BOOTSTRAP_ADMIN_PASSWORD=change-me-now
MODEL_ROUTER_BOOTSTRAP_TENANT_NAME=Default Tenant
MODEL_ROUTER_BOOTSTRAP_TENANT_SLUG=default
MODEL_ROUTER_DEFAULT_MODEL_NAME=Huihui-Qwen3.5-35B-A3B-abliterated.Q4_K_M.gguf
MODEL_ROUTER_DEFAULT_UPSTREAM_BASE_URL=http://127.0.0.1:8080/v1
MODEL_ROUTER_DEFAULT_UPSTREAM_MODEL_NAME=Huihui-Qwen3.5-35B-A3B-abliterated.Q4_K_M.gguf

# Optional managed llama-server mode.
# Use upstream_base_url=managed://llama-server on a model route and add a matching entry here.
# MODEL_ROUTER_MANAGED_LLAMA_MODELS_JSON={"Huihui-Qwen3.5-35B-A3B-abliterated.Q4_K_M.gguf":{"model_path":"/models/Huihui-Qwen3.5-35B-A3B-abliterated.Q4_K_M.gguf","cli_args":["--ctx-size","16384","--n-gpu-layers","999"],"idle_timeout_seconds":900}}
# MODEL_ROUTER_MANAGED_LLAMA_PORT=8090
