# Copy this to `.env.stack` and adjust values before first launch.

# Persistent data directories
MODEL_ROUTER_DATA_DIR=./runtime/model-router
OPEN_WEBUI_DATA_DIR=./runtime/open-webui
HERMES_HOME=./runtime/hermes

# Published ports
MODEL_ROUTER_PORT=4000
OPEN_WEBUI_PORT=3002
LLAMA_PORT=8081

# Router bootstrap
MODEL_ROUTER_ENV=production
MODEL_ROUTER_JWT_SECRET_KEY=replace-with-a-long-random-secret
MODEL_ROUTER_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
MODEL_ROUTER_BOOTSTRAP_ADMIN_PASSWORD=change-me-now
MODEL_ROUTER_BOOTSTRAP_TENANT_NAME=Default Tenant
MODEL_ROUTER_BOOTSTRAP_TENANT_SLUG=default

# Open WebUI talks to model-router with this seeded tenant API key.
OPEN_WEBUI_ROUTER_API_KEY=mrk_01234567_replace_with_a_long_random_secret
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
OPEN_WEBUI_PATCHED_IMAGE=open-webui-router:local
OPENWEBUI_INLINE_FULL_CONTEXT_MAX_CHARS=16000

# Seed the router with the Open WebUI service key on first start.
MODEL_ROUTER_BOOTSTRAP_API_KEYS_JSON=[{"tenant_slug":"default","name":"Open WebUI Service Key","raw_key":"mrk_01234567_replace_with_a_long_random_secret","scopes":["models:read","chat:completions"]}]

# Required default route: Hermes behind model-router.
# Add the gemma route if you launch the stack with `--profile llama`.
MODEL_ROUTER_BOOTSTRAP_ROUTES_JSON=[{"name":"hermes-agent","description":"Hermes API server","upstream_base_url":"http://hermes:8642/v1","upstream_model_name":"hermes-agent","allowed_tenant_slugs":["default"]},{"name":"gemma-4-31B-it-qat-UD-Q4_K_XL.gguf","description":"Gemma 4 31B via llama.cpp (turboquant)","upstream_base_url":"http://llama-cpp:8080/v1","upstream_model_name":"gemma-4-31B-it-qat-UD-Q4_K_XL.gguf","allowed_tenant_slugs":["default"],"max_context_tokens":192000}]

# Hermes container/image settings
HERMES_IMAGE=nousresearch/hermes-agent:latest
HERMES_UID=1000
HERMES_GID=1000
HERMES_API_MODEL_NAME=hermes-agent

# Optional llama.cpp sidecar settings. Start it with `--profile llama`.
LLAMA_CPP_IMAGE=vito974/llama-cpp-turboquant:server-cuda12
LLAMA_CACHE_DIR=./runtime/llama-cpp
LLAMA_HF_REPO=unsloth/gemma-4-31B-it-qat-GGUF:UD-Q4_K_XL
LLAMA_SPEC_TYPE=none
LLAMA_CTX_SIZE=192000
LLAMA_CACHE_TYPE_K=turbo4
LLAMA_CACHE_TYPE_V=turbo3
LLAMA_BATCH_SIZE=2048
LLAMA_UBATCH_SIZE=512
LLAMA_THREADS=8
LLAMA_N_CPU_MOE=0

# SearXNG web search
ENABLE_WEB_SEARCH=true
WEB_SEARCH_ENGINE=searxng
SEARXNG_QUERY_URL=http://searxng:8080
SEARXNG_PORT=8088
WEBUI_SECRET_KEY=change-me-to-a-long-random-string
